{
  "name": "scriptcraft-ai",
  "version": "1.0.0",
  "description": "AI 剧本创作软件 - 五大创作模块一体化平台",
  "type": "module",
    "scripts": {
      "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
      "dev:mock": "concurrently \"npm run dev:server:mock\" \"npm run dev:client\"",
      "dev:server": "tsx watch server/index.ts",
      "dev:server:mock": "MOCK_AI=true tsx watch server/index.ts",
      "dev:client": "vite",
      "build": "tsc && vite build",
      "build:client": "vite build",
      "build:server": "tsc -p tsconfig.server.json",
      "preview": "vite preview",
      "start": "node dist/server/index.js",
      "type-check": "tsc --noEmit"
    },
  "dependencies": {
    "@tencent-ai/agent-sdk": "^0.3.186",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongodb": "^6.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
